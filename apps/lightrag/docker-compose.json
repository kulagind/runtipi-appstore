{
  "$schema": "../dynamic-compose-schema.json",
  "services": [
    {
      "name": "lightrag",
      "image": "ghcr.io/hkuds/lightrag:1.3.8",
      "isMain": true,
      "internalPort": 18085,
      "addPorts": [
        {
          "hostPort": 9621,
          "containerPort": 9621
        }
      ],
      "environment": {
        "TZ": "${TZ}"
      },
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/rag_storage",
          "containerPath": "/app/data/rag_storage"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/inputs",
          "containerPath": "/app/data/inputs"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/config.ini",
          "containerPath": "/app/config.ini"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/.env",
          "containerPath": "/app/.env"
        }
      ]
    }    
  ]
}
