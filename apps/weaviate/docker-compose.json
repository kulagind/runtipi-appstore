{
  "$schema": "../dynamic-compose-schema.json",
  "services": [
    {
      "name": "weaviate",
      "image": "cr.weaviate.io/semitechnologies/weaviate:1.36.6",
      "isMain": true,
      "internalPort": 8080,
      "addPorts": [
        {
          "hostPort": 50051,
          "containerPort": 50051
        },
        {
          "hostPort": 8089,
          "containerPort": 8080
        }
      ],
      "environment": {
        "TZ": "${TZ}",
        "AUTHENTICATION_ANONYMOUS_ACCESS_ENABLED": "${AUTHENTICATION_ANONYMOUS_ACCESS_ENABLED:-false}",
        "AUTHENTICATION_APIKEY_ENABLED": "${AUTHENTICATION_APIKEY_ENABLED:-true}",
        "AUTHENTICATION_APIKEY_ALLOWED_KEYS": "${AUTHENTICATION_APIKEY_ALLOWED_KEYS:-change-me-api-key}",
        "AUTHENTICATION_APIKEY_USERS": "${AUTHENTICATION_APIKEY_USERS:-admin}"
      },
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/var/lib/weaviate"
        }
      ]
    }    
  ]
}
