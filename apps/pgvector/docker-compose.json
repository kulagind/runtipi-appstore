{
  "$schema": "../dynamic-compose-schema.json",
  "services": [
    {
      "name": "pgvector",
      "image": "pgvector/pgvector:pg17",
      "isMain": true,
      "internalPort": 5432,
      "addPorts": [
        {
          "hostPort": 5432,
          "containerPort": 5432
        }
      ],
      "environment": {
        "TZ": "${TZ}",
        "POSTGRES_DB": "${POSTGRES_DB:-tipi}",
        "POSTGRES_USER": "${POSTGRES_USER:-tipi}",
        "POSTGRES_PASSWORD": "${POSTGRES_PASSWORD}"
      },
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/var/lib/postgresql/data"
        },
        {
          "hostPath": "./init",
          "containerPath": "/docker-entrypoint-initdb.d"
        }
      ],
      "healthCheck": {
        "interval": "10s",
        "timeout": "5s",
        "retries": 10,
        "test": "pg_isready -U ${POSTGRES_USER:-tipi} -d ${POSTGRES_DB:-tipi}"
      }
    }
  ]
}
